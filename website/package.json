{
  "name": "@comax/website",
  "private": true,
  "version": "0.1.0",
  "description": "Comax Secrets marketing + docs site (Next.js App Router, Vercel). Separate from the embedded dashboard SPA.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:site-url": "node scripts/check-site-url.mjs",
    "check:docs-drift": "node scripts/check-docs-drift.mjs",
    "check:docs-coverage": "node scripts/check-docs-coverage.mjs",
    "check:token-parity": "node scripts/check-token-parity.mjs",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run check:docs-drift && npm run check:docs-coverage && npm run check:token-parity && npm run check:site-url"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.2",
    "clsx": "^2.1.1",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.20",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.24.2",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
