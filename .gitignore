# Worktree
.worktrees/

# Build artefacts
/bin/
# Release cross-compile output (make xbuild-release). Built fresh on CI and
# attached to the GitHub Release; never committed.
/dist/
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Coverage
coverage.out
coverage.html
coverage.txt
coverage
coverage-*
cov_*
/cover

# Local test/bench scratch output
*.log

# PRP workflow scratch directories (per-feature plans/reports)
.claude/PRPs/

# Claude Code local session artefacts (per-session, machine-local)
.claude/receipts/

# v0.2 Stop-loop bounded counter and advisory locks (session-local).
# STATE.md and fix-task.md remain git-tracked per plan §4.
.claude/state/loop-counter.json
.claude/state/*.lock
# dashboard-truthfulness M1 — completion-ledger entries ARE git-tracked, but the
# per-entry write lock + atomic tmp are local-only ephemera. The single-level
# glob above does not reach this subdir, so name them explicitly to keep
# crash-leaked locks/tmps out of the tracked register directory.
.claude/state/completion-ledger/*.lock
.claude/state/completion-ledger/*.tmp
# Codex stop-loop bridge scratch input — local-only.
.claude/state/codex-stop-loop-input.txt
# Dogfood ephemera (fixtures + sandboxes) — never committed.
.claude/state/dogfood-*/
# v0.2.7 hook-trace shard ledgers (per-invocation observability — local only).
.claude/state/hook-trace/
# v0.2.7 hook capability probe cache (per-machine binary path + mtime — local only).
.claude/state/hook-caps.json
# v0.3.0 auto-handoff append-only log (per-session cost-tier events — local only).
.claude/state/auto-handoff-log.jsonl
# v1.5.0-m1 — session-ledger repo opt-in scope. Default is global
# (~/.local/share/ecc-homunculus/projects/<projectId>/.session-ledgers/),
# but MCCP_SESSION_LEDGER_SCOPE=repo or hybrid writes here too. Per-session
# JSON files are never appropriate to commit.
.claude/state/session-ledgers/

# v1.3.0 Observability Surface II — derive cache (M1+, never committed).
# Cache layer is per-session/per-machine; sources of truth remain receipts,
# envelopes, and STATE.md. Pattern mirrors .claude/state/*.lock above.
.claude/cache/

.claude/tmp/
.claude/settings.local.json
.github/skills/
dashboard/.claude/

# Go workspace files (kept out of version control)
go.work
go.work.sum

# Editor / IDE
.vscode/
.idea/
.playwright-mcp/
*.swp
*.stackdump
.impeccable/*
!.impeccable/design.json

# Project-specific (per plan: keys and DB live outside the repo)
.secretrc
.secretrc.*
/data/
/keys/
*.key

# Compose bind-mount artefacts (deploy/compose/{data,keys})
deploy/compose/data/
deploy/compose/keys/
**/secrets.db
**/secrets.db-journal
**/secrets.db-wal
**/secrets.db-shm

# Local env files (the very thing we're replacing)
.env
.env.*
!.env.example

# M7 infra-config-templating PoC — `secret render` staging output. Rendered
# config files contain plaintext secrets; render refuses to write to any
# non-gitignored path, so this staging dir is the sanctioned sink.
tmp-render/

# Dashboard SPA build output. Committed only via .gitkeep so the
# `//go:embed all:dist` directive resolves to at least one entry even
# before `make dashboard` has produced a real bundle.
/internal/server/dashboard/dist/*
!/internal/server/dashboard/dist/.gitkeep

# Frontend toolchain artefacts (npm/Vite/Playwright).
/dashboard/node_modules/
/dashboard/dist/
/dashboard/.vite/
/dashboard/playwright-report/
/dashboard/test-results/
/dashboard/coverage/
