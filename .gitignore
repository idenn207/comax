# Worktree
.worktrees/

# Build artefacts
/bin/
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Coverage
coverage.out
coverage.html
coverage.txt
coverage
coverage-*
cov_*
/cover

# Local test/bench scratch output
*.log

# PRP workflow scratch directories (per-feature plans/reports)
.claude/PRPs/

# Claude Code local session artefacts (per-session, machine-local)
.claude/receipts/
.claude/state/
.claude/tmp/
.claude/settings.local.json
web/dashboard/.claude/

# Go workspace files (kept out of version control)
go.work
go.work.sum

# Editor / IDE
.vscode/
.idea/
.playwright-mcp/
.impeccable/
*.swp
*.stackdump

# Project-specific (per plan: keys and DB live outside the repo)
.secretrc
.secretrc.*
/data/
/keys/
*.key

# Compose bind-mount artefacts (deploy/compose/{data,keys})
deploy/compose/data/
deploy/compose/keys/
**/secrets.db
**/secrets.db-journal
**/secrets.db-wal
**/secrets.db-shm

# Local env files (the very thing we're replacing)
.env
.env.*
!.env.example

# Dashboard SPA build output. Committed only via .gitkeep so the
# `//go:embed all:dist` directive resolves to at least one entry even
# before `make dashboard` has produced a real bundle.
/internal/server/dashboard/dist/*
!/internal/server/dashboard/dist/.gitkeep

# Frontend toolchain artefacts (npm/Vite/Playwright).
/web/dashboard/node_modules/
/web/dashboard/dist/
/web/dashboard/.vite/
/web/dashboard/playwright-report/
/web/dashboard/test-results/
/web/dashboard/coverage/
